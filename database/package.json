{
  "name": "@recipe-app/database",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:migrate:dry": "bun run scripts/migrate.ts --dry-run",
    "db:migrate:status": "bun run scripts/migrate.ts --status",
    "db:migrate:rollback": "bun run scripts/migrate.ts --rollback",
    "db:migrate:rollback-to": "bun run scripts/migrate.ts --rollback-to=010",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.4",
    "typescript": "^6.0.2"
  }
}
