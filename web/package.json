{
  "name": "web",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build": "nuxt build",
    "dev": "fuser -k 3000/tcp 2>/dev/null || true && nuxt dev --port 3000 --host 0.0.0.0",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    "lint": "oxlint && bash scripts/check-i18n.sh",
    "lint:fix": "oxlint --fix",
    "lint:es": "eslint . --ext .vue,.ts,.js",
    "lint:es:fix": "eslint . --ext .vue,.ts,.js --fix",
    "format": "prettier --write \"**/*.{vue,ts,js,json,css}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{vue,ts,js,json,css}\" --ignore-path .prettierignore"
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/sitemap": "^7.6.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/vue-virtual": "^3.13.23",
    "@vite-pwa/nuxt": "^1.1.1",
    "nuxt": "^4.3.1",
    "vercel": "^50.28.0",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.33",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^28.1.0",
    "lighthouse": "^13.0.3",
    "oxlint": "^1.49.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.6"
  }
}
