{
  "name": "web",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build": "nuxt build",
    "dev": "fuser -k 3000/tcp 2>/dev/null || true && nuxt dev --port 3000 --host 0.0.0.0",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install",
    "lint": "oxlint && bash scripts/check-i18n.sh",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@supabase/supabase-js": "^2.97.0",
    "nuxt": "^4.3.1",
    "vercel": "^50.28.0",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.33",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^28.1.0",
    "oxlint": "^1.49.0",
    "vitest": "^4.0.18"
  }
}
