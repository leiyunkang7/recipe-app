# Database
DATABASE_URL=postgresql://recipe_user:recipe_pass@localhost:5432/recipe_app

# File uploads
UPLOAD_DIR=./uploads

# Mock data mode (set to true to use mock data instead of real database)
ENABLE_MOCK_DATA=false

# Google Analytics 4 (get from https://analytics.google.com)
# GA_ID=G-XXXXXXXXXX

# Sentry Error Tracking & Performance Monitoring (https://sentry.io)
# Get your DSN from: https://sentry.io/settings/<your-org>/projects/<your-project>/keys/
SENTRY_DSN=https://example@sentry.io/projectId
SENTRY_ENABLED=true
# Auth token for source map uploads (from https://sentry.io/settings/<org>/api-keys/)
# Required scopes: project:write, release:admin
SENTRY_AUTH_TOKEN=
# Sentry organization slug (e.g., your-company-name)
SENTRY_ORG=your-org-slug
# Sentry project name
SENTRY_PROJECT=recipe-app-web
# Server-side tracing sample rate (0.0–1.0, default: 0.05 in prod)
SENTRY_SERVER_SAMPLE_RATE=0.05
