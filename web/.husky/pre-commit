#!/bin/bash

echo "🔍 Running pre-commit checks..."

cd "$(git rev-parse --show-toplevel)/web"

# Stop if any command fails
set -e

echo "📋 Step 1: Lint check..."
npm run lint

echo "🔎 Step 2: Type check..."
npx vue-tsc --noEmit

echo "🏗️ Step 3: Build check..."
npm run build

echo "✅ All checks passed!"
