{
  "name": "recipe-app",
  "private": true,
  "workspaces": [
    "shared/*",
    "services/*",
    "cli",
    "database"
  ],
  "test": 1,
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "oxlint": "^1.59.0",
    "typescript": "^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "source /root/.openclaw/workspace/scripts/recipe-app-build-lock.sh && bun run build:shared && bun run build:database && bun run build:services && bun run build:cli",
    "build:shared": "cd shared/types && bun run build",
    "build:database": "cd database && bun run build",
    "build:services": "for d in services/*/; do (cd \"$d\" && bun run build); done",
    "build:cli": "cd cli && bun run build",
    "lint": "oxlint --ignore-path .oxlintignore",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@recipe-app/email-service": "workspace:*",
    "web": "^0.0.2"
  }
}
